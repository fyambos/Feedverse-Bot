# Required
DISCORD_TOKEN=<BOT_TOKEN>
DISCORD_CLIENT_ID=<APPLICATION_ID>

# Optional (bot operator only): if set, registers commands to a single guild (fast for dev)
# Anyone inviting/using the bot does NOT need access to this file.
DISCORD_GUILD_ID=

# Note:
# - If DISCORD_GUILD_ID is set, commands are registered to that guild only (fast).
# - If unset, commands are registered globally (slower to appear).

# Optional: path to the AU data file
AU_DATA_PATH=./data/au_summaries_filled.json

# Optional: used by /drop to include a clickable join link.
# Must include {CODE}. Example: https://feedverse.com/join/{CODE}
FEEDVERSE_JOIN_URL_TEMPLATE=

# Optional alternative: base URL for your website.
# If FEEDVERSE_JOIN_URL_TEMPLATE is unset, /drop will link to {base}/join/{CODE}
FEEDVERSE_WEB_BASE_URL=

# Optional: enable "pretty" /drop embeds by resolving invite codes to scenario metadata.
# Example: http://localhost:8080
FEEDVERSE_API_BASE_URL=
